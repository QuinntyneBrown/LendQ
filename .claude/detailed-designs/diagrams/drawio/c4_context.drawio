<mxfile host="app.diagrams.net">
  <diagram name="C4 Context" id="c4ctx">
    <mxGraphModel dx="1024" dy="680" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="850" pageHeight="1100" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>
        <mxCell id="title" value="LendQ — C4 Context Diagram" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;fontSize=16;fontStyle=1;" parent="1" vertex="1">
          <mxGeometry x="250" y="20" width="300" height="30" as="geometry"/>
        </mxCell>
        <!-- Actors -->
        <mxCell id="borrower" value="Borrower" style="shape=umlActor;verticalLabelPosition=bottom;verticalAlign=top;html=1;outlineConnect=0;fillColor=#dae8fc;strokeColor=#6c8ebf;" parent="1" vertex="1">
          <mxGeometry x="100" y="100" width="40" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="creditor" value="Creditor" style="shape=umlActor;verticalLabelPosition=bottom;verticalAlign=top;html=1;outlineConnect=0;fillColor=#d5e8d4;strokeColor=#82b366;" parent="1" vertex="1">
          <mxGeometry x="400" y="100" width="40" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="admin" value="Admin" style="shape=umlActor;verticalLabelPosition=bottom;verticalAlign=top;html=1;outlineConnect=0;fillColor=#fff2cc;strokeColor=#d6b656;" parent="1" vertex="1">
          <mxGeometry x="680" y="100" width="40" height="60" as="geometry"/>
        </mxCell>
        <!-- System -->
        <mxCell id="lendq" value="&lt;b&gt;LendQ System&lt;/b&gt;&lt;br&gt;[Software System]&lt;br&gt;&lt;br&gt;Peer-to-peer lending management&lt;br&gt;platform for tracking loans,&lt;br&gt;payments, and schedules." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#1e3a5f;fontColor=#ffffff;strokeColor=#1e3a5f;arcSize=8;" parent="1" vertex="1">
          <mxGeometry x="260" y="260" width="300" height="120" as="geometry"/>
        </mxCell>
        <!-- Email -->
        <mxCell id="email" value="&lt;b&gt;Email Service&lt;/b&gt;&lt;br&gt;[External System]&lt;br&gt;&lt;br&gt;SMTP relay for password resets&lt;br&gt;and notification emails." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#999999;fontColor=#ffffff;strokeColor=#666666;arcSize=8;" parent="1" vertex="1">
          <mxGeometry x="310" y="470" width="200" height="100" as="geometry"/>
        </mxCell>
        <!-- Edges -->
        <mxCell id="e1" value="View loans, make payments,&lt;br&gt;reschedule" style="endArrow=classic;html=1;strokeWidth=1;fontSize=10;" parent="1" source="borrower" target="lendq" edge="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e2" value="Create loans, track payments,&lt;br&gt;adjust terms" style="endArrow=classic;html=1;strokeWidth=1;fontSize=10;" parent="1" source="creditor" target="lendq" edge="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e3" value="Manage users,&lt;br&gt;roles, permissions" style="endArrow=classic;html=1;strokeWidth=1;fontSize=10;" parent="1" source="admin" target="lendq" edge="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e4" value="Send notifications" style="endArrow=classic;html=1;strokeWidth=1;fontSize=10;" parent="1" source="lendq" target="email" edge="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
