@startuml
actor User
participant PaymentController
participant AdjustmentService
queue Outbox

User -> PaymentController : POST /schedule-adjustments/reschedule
alt borrower requires approval
  PaymentController -> AdjustmentService : create pending request
else creditor direct apply
  PaymentController -> AdjustmentService : create new schedule version
  AdjustmentService -> Outbox : schedule_rescheduled
end
PaymentController --> User : accepted
@enduml
