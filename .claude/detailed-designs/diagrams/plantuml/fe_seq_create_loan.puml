@startuml
actor Creditor
participant LoanForm
participant BorrowerDirectorySelect
participant LoanApi
participant QueryCache
participant Router

Creditor -> BorrowerDirectorySelect : search borrower
BorrowerDirectorySelect -> LoanApi : GET /users/borrowers
Creditor -> LoanForm : submit loan
LoanForm -> LoanApi : POST /loans
LoanApi --> QueryCache : invalidate loans
LoanForm -> Router : go to loan detail
@enduml
