<mxfile host="app.diagrams.net">
  <diagram name="C4 Container" id="c4cont">
    <mxGraphModel dx="1024" dy="680" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="850" pageHeight="1100" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>
        <mxCell id="title" value="LendQ — C4 Container Diagram" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;fontSize=16;fontStyle=1;" parent="1" vertex="1">
          <mxGeometry x="240" y="15" width="320" height="30" as="geometry"/>
        </mxCell>
        <!-- User -->
        <mxCell id="user" value="User" style="shape=umlActor;verticalLabelPosition=bottom;verticalAlign=top;html=1;outlineConnect=0;fillColor=#dae8fc;strokeColor=#6c8ebf;" parent="1" vertex="1">
          <mxGeometry x="395" y="55" width="30" height="45" as="geometry"/>
        </mxCell>
        <!-- System boundary -->
        <mxCell id="boundary" value="LendQ System" style="rounded=1;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#1e3a5f;dashed=1;dashPattern=5 5;verticalAlign=top;fontStyle=1;fontSize=12;strokeWidth=2;" parent="1" vertex="1">
          <mxGeometry x="60" y="145" width="700" height="360" as="geometry"/>
        </mxCell>
        <!-- Frontend SPA -->
        <mxCell id="spa" value="&lt;b&gt;Frontend SPA&lt;/b&gt;&lt;br&gt;[Container: Angular]&lt;br&gt;&lt;br&gt;User interface for&lt;br&gt;all LendQ features" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#438DD5;fontColor=#ffffff;strokeColor=#3a7fc2;arcSize=10;" parent="1" vertex="1">
          <mxGeometry x="310" y="170" width="180" height="90" as="geometry"/>
        </mxCell>
        <!-- ASP.NET Core API -->
        <mxCell id="api" value="&lt;b&gt;ASP.NET Core REST API&lt;/b&gt;&lt;br&gt;[Container: C#/ASP.NET Core]&lt;br&gt;&lt;br&gt;Business logic, REST endpoints,&lt;br&gt;authorization enforcement" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#438DD5;fontColor=#ffffff;strokeColor=#3a7fc2;arcSize=10;" parent="1" vertex="1">
          <mxGeometry x="290" y="320" width="220" height="90" as="geometry"/>
        </mxCell>
        <!-- Auth Service -->
        <mxCell id="auth" value="&lt;b&gt;Auth Service&lt;/b&gt;&lt;br&gt;[Component: JWT]&lt;br&gt;&lt;br&gt;Token issuance,&lt;br&gt;verification" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#438DD5;fontColor=#ffffff;strokeColor=#3a7fc2;arcSize=10;" parent="1" vertex="1">
          <mxGeometry x="80" y="180" width="150" height="80" as="geometry"/>
        </mxCell>
        <!-- Notification Service -->
        <mxCell id="notif" value="&lt;b&gt;Notification Service&lt;/b&gt;&lt;br&gt;[Component: C#]&lt;br&gt;&lt;br&gt;In-app alerts &amp;&lt;br&gt;email dispatch" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#438DD5;fontColor=#ffffff;strokeColor=#3a7fc2;arcSize=10;" parent="1" vertex="1">
          <mxGeometry x="570" y="180" width="160" height="80" as="geometry"/>
        </mxCell>
        <!-- Database -->
        <mxCell id="db" value="&lt;b&gt;PostgreSQL&lt;/b&gt;&lt;br&gt;[Container: Database]&lt;br&gt;&lt;br&gt;Users, loans, payments,&lt;br&gt;notifications, audit logs" style="shape=cylinder3;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;size=10;fillColor=#438DD5;fontColor=#ffffff;strokeColor=#3a7fc2;" parent="1" vertex="1">
          <mxGeometry x="80" y="340" width="160" height="100" as="geometry"/>
        </mxCell>
        <!-- SMTP -->
        <mxCell id="smtp" value="&lt;b&gt;SMTP Server&lt;/b&gt;&lt;br&gt;[External System]" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#999999;fontColor=#ffffff;strokeColor=#666666;arcSize=10;" parent="1" vertex="1">
          <mxGeometry x="590" y="540" width="150" height="50" as="geometry"/>
        </mxCell>
        <!-- Edges -->
        <mxCell id="e1" value="HTTPS" style="endArrow=classic;html=1;strokeWidth=1;fontSize=9;" parent="1" source="user" target="spa" edge="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e2" value="REST/JSON" style="endArrow=classic;html=1;strokeWidth=1;fontSize=9;" parent="1" source="spa" target="api" edge="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e3" value="Authenticate" style="endArrow=classic;html=1;strokeWidth=1;fontSize=9;" parent="1" source="api" target="auth" edge="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e4" value="Read/Write" style="endArrow=classic;html=1;strokeWidth=1;fontSize=9;" parent="1" source="api" target="db" edge="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e5" value="Trigger alerts" style="endArrow=classic;html=1;strokeWidth=1;fontSize=9;" parent="1" source="api" target="notif" edge="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e6" value="Send emails" style="endArrow=classic;html=1;strokeWidth=1;fontSize=9;" parent="1" source="notif" target="smtp" edge="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e7" value="Verify" style="endArrow=classic;html=1;strokeWidth=1;fontSize=9;" parent="1" source="auth" target="db" edge="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
