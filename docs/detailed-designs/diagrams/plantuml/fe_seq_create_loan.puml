@startuml
actor Creditor
participant LoanFormComponent
participant BorrowerDirectorySelectComponent
participant LoanService
participant QueryCache
participant Router

Creditor -> BorrowerDirectorySelectComponent : search borrower
BorrowerDirectorySelectComponent -> LoanService : GET /users/borrowers
Creditor -> LoanFormComponent : submit loan
LoanFormComponent -> LoanService : POST /loans
LoanService --> QueryCache : invalidate loans
LoanFormComponent -> Router : go to loan detail
@enduml
