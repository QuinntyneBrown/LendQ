@startuml
actor Creditor
participant LoanForm
participant BorrowerDirectorySelect
participant LoanService
participant StateService
participant NavigationManager

Creditor -> BorrowerDirectorySelect : search borrower
BorrowerDirectorySelect -> LoanService : GET /users/borrowers
Creditor -> LoanForm : submit loan
LoanForm -> LoanService : POST /loans
LoanService --> StateService : invalidate loans
LoanForm -> NavigationManager : go to loan detail
@enduml
