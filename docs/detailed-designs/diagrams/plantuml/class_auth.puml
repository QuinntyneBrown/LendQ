@startuml class_auth
!theme plain
skinparam dpi 150
skinparam defaultFontSize 10
skinparam classAttributeIconSize 0

title Authentication Module — Class Diagram

class AuthController {
  +login(email, password): TokenResponse
  +signup(payload): UserResponse
  +forgot_password(email): MessageResponse
  +reset_password(token, password): MessageResponse
  +refresh_token(refresh_token): TokenResponse
  +logout(): MessageResponse
}

class AuthService {
  -user_repo: UserRepository
  -token_service: TokenService
  -email_service: EmailService
  +authenticate(email, password): User
  +register(name, email, password): User
  +initiate_password_reset(email): void
  +complete_password_reset(token, password): void
}

class TokenService {
  -secret_key: str
  -access_ttl: int
  -refresh_ttl: int
  +create_access_token(user_id, roles): str
  +create_refresh_token(user_id): str
  +decode_token(token): dict
  +revoke_token(jti): void
}

class PasswordService {
  +hash_password(plain): str
  +verify_password(plain, hashed): bool
  +generate_reset_token(): str
  +validate_reset_token(token): str
}

AuthController --> AuthService
AuthService --> TokenService
AuthService --> PasswordService
@enduml
