@startuml
left to right direction
skinparam shadowing false
actor User
rectangle "Browser\nAngular SPA" as spa
rectangle "ASP.NET Core API" as api
database "PostgreSQL" as db
queue "Redis + Background Services" as infra

User --> spa : interacts
spa --> api : HTTPS JSON + SSE
api --> db : persistence
api --> infra : jobs / stream events
@enduml
