@startuml
participant HttpInterceptor
participant AuthService
participant API

HttpInterceptor -> API : request with in-memory token
API --> HttpInterceptor : 401
HttpInterceptor -> AuthService : single-flight refresh
AuthService -> API : POST /auth/refresh\ncookie + CSRF
API --> AuthService : new access token + user
AuthService --> HttpInterceptor : retry original request
HttpInterceptor -> API : retried request
API --> HttpInterceptor : success
@enduml
