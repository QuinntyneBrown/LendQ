@startuml
participant HttpClient
participant AuthService
participant API

HttpClient -> API : request with in-memory token
API --> HttpClient : 401
HttpClient -> AuthService : single-flight refresh
AuthService -> API : POST /auth/refresh\ncookie + CSRF
API --> AuthService : new access token + user
AuthService --> HttpClient : retry original request
HttpClient -> API : retried request
API --> HttpClient : success
@enduml
