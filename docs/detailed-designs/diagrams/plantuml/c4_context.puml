@startuml c4_context
!theme plain
skinparam dpi 150
skinparam pageMargin 10
skinparam defaultFontSize 11

title LendQ — C4 Context Diagram

actor "Borrower" as borrower
actor "Creditor" as creditor
actor "Admin" as admin

rectangle "LendQ System" as lendq {
}

rectangle "Email Service\n(SMTP)" as email

borrower --> lendq : View loans,\nmake payments,\nreschedule
creditor --> lendq : Create loans,\ntrack payments,\nadjust terms
admin --> lendq : Manage users,\nroles, permissions
lendq --> email : Send notifications\n(password reset, alerts)
@enduml
