@startuml
left to right direction
skinparam shadowing false
rectangle "Browser\nReact SPA" as browser
rectangle "Edge / Reverse Proxy\nTLS, headers, routing" as edge
rectangle "Flask API\nAuth, loans, payments, notifications" as api
database "PostgreSQL" as db
queue "Redis" as redis
rectangle "Celery Workers\nnotifications, email, projections" as worker
rectangle "Celery Beat\nscheduled jobs" as beat

browser --> edge : HTTPS
edge --> api : proxied requests
api --> db : OLTP data
api --> redis : rate limit / queue publish
worker --> redis : consume jobs
beat --> redis : schedule jobs
worker --> db : update projections
@enduml
