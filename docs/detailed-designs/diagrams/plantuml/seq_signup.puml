@startuml seq_signup
!theme plain
skinparam dpi 150
skinparam defaultFontSize 10
skinparam sequenceMessageAlign center

title Sign-Up Sequence

actor User
participant "AuthController" as ctrl
participant "AuthService" as svc
participant "UserRepository" as repo
participant "PasswordService" as pwd
participant "RoleRepository" as role_repo

User -> ctrl : POST /api/auth/signup\n{name, email, password}
ctrl -> svc : register(name, email, password)
svc -> repo : find_by_email(email)
repo --> svc : User | None

alt Email already exists
  svc --> ctrl : ConflictError
  ctrl --> User : 409 Email already registered
else Email available
  svc -> pwd : hash_password(password)
  pwd --> svc : password_hash
  svc -> repo : save(new User)
  repo --> svc : User
  svc -> role_repo : find_by_name("Borrower")
  role_repo --> svc : Role
  svc -> repo : assign_role(user, role)
  svc --> ctrl : UserResponse
  ctrl --> User : 201 {user}
end
@enduml
