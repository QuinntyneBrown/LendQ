@startuml
actor User
participant SPA
participant AuthController
participant AuthService
database UserRepo
queue Outbox
participant BackgroundService

User -> SPA : submit registration
SPA -> AuthController : POST /auth/signup
AuthController -> AuthService : register()
AuthService -> UserRepo : create inactive user
AuthService -> Outbox : enqueue verification event
Outbox -> BackgroundService : verification email job
AuthController --> SPA : 201 created
SPA --> User : show verify-email state
@enduml
