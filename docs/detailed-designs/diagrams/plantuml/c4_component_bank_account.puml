@startuml
left to right direction
skinparam shadowing false
rectangle "BankAccountController" as controller
rectangle "BankAccountService" as service
rectangle "RecurringDepositService" as recurring
rectangle "TransactionService" as txn
queue "Outbox Publisher" as outbox
database "bank_accounts" as db

controller --> service
controller --> recurring
service --> txn
service --> db
txn --> db
recurring --> txn
service --> outbox
recurring --> outbox
@enduml
