@startuml c4_component_notification
!theme plain
skinparam dpi 150
skinparam defaultFontSize 10
skinparam componentStyle rectangle

title C4 Component — Notification Module

package "Flask REST API" {
  component "**NotificationController**\n[Blueprint]\nlist, count, mark-read,\nmark-all-read" as ctrl #438DD5
  component "**NotificationService**\n[Service]\nCreate, list, mark-read,\ndispatch email alerts" as svc #438DD5
  component "**NotificationRepository**\n[Repository]" as repo #85BBF0
  component "**EmailService**\n[Component]\nSMTP dispatch" as email #85BBF0
}

component "**Other Services**\n[LoanService, PaymentService]\nTrigger notifications" as callers #999999
component "**SMTP Server**\n[External]" as smtp #999999

ctrl --> svc
svc --> repo
svc --> email
callers ..> svc
email --> smtp
@enduml
