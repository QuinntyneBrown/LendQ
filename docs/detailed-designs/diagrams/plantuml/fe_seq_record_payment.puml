@startuml
actor User
participant RecordPaymentDialog
participant PaymentService
participant StateService
participant Toasts

User -> RecordPaymentDialog : confirm payment
RecordPaymentDialog -> PaymentService : POST /payments\nIdempotency-Key
PaymentService --> StateService : invalidate loan + dashboard
StateService --> RecordPaymentDialog : refreshed data
RecordPaymentDialog -> Toasts : show transaction id
@enduml
