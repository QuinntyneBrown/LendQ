@startuml
actor User
participant RecordPaymentDialogComponent
participant PaymentService
participant QueryCache
participant SnackBarService

User -> RecordPaymentDialogComponent : confirm payment
RecordPaymentDialogComponent -> PaymentService : POST /payments\nIdempotency-Key
PaymentService --> QueryCache : invalidate loan + dashboard
QueryCache --> RecordPaymentDialogComponent : refreshed data
RecordPaymentDialogComponent -> SnackBarService : show transaction id
@enduml
