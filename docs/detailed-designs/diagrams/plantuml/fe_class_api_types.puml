@startuml fe_class_api_types
!theme plain
skinparam dpi 150
skinparam defaultFontSize 9
skinparam classAttributeIconSize 0

title Frontend — Core TypeScript Types & API Client

interface ApiClient {
  +baseURL: string
  +get<T>(url, params?): Promise<T>
  +post<T>(url, data): Promise<T>
  +put<T>(url, data): Promise<T>
  +delete(url): Promise<void>
  -attachAuthHeader(config): config
  -handleTokenRefresh(error): Promise
}

interface PaginatedResponse<T> {
  +items: T[]
  +total: number
  +page: number
  +per_page: number
  +pages: number
}

interface ApiError {
  +error: string
  +code: string
  +details?: Record<string, string[]>
}

interface User {
  +id: string
  +name: string
  +email: string
  +is_active: boolean
  +roles: Role[]
  +created_at: string
  +updated_at: string
}

interface Role {
  +id: string
  +name: "Admin" | "Creditor" | "Borrower"
  +description: string
  +permissions: string[]
}

interface Loan {
  +id: string
  +creditor_id: string
  +borrower_id: string
  +creditor_name: string
  +borrower_name: string
  +description: string
  +principal: number
  +interest_rate: number
  +repayment_frequency: RepaymentFrequency
  +start_date: string
  +status: LoanStatus
  +outstanding_balance: number
  +notes: string
}

interface Payment {
  +id: string
  +loan_id: string
  +amount_due: number
  +amount_paid: number
  +due_date: string
  +paid_date: string | null
  +original_due_date: string | null
  +status: PaymentStatus
  +notes: string
}

interface Notification {
  +id: string
  +type: NotificationType
  +message: string
  +loan_id: string | null
  +is_read: boolean
  +created_at: string
}

enum LoanStatus {
  ACTIVE
  PAUSED
  PAID_OFF
  OVERDUE
  DEFAULTED
}

enum PaymentStatus {
  SCHEDULED
  PAID
  PAUSED
  RESCHEDULED
  OVERDUE
  PARTIAL
}

enum NotificationType {
  PAYMENT_DUE
  PAYMENT_OVERDUE
  PAYMENT_RECEIVED
  SCHEDULE_CHANGED
  LOAN_MODIFIED
  SYSTEM
}

enum RepaymentFrequency {
  WEEKLY
  BIWEEKLY
  MONTHLY
  CUSTOM
}

ApiClient ..> PaginatedResponse
ApiClient ..> ApiError
Loan --> LoanStatus
Loan --> RepaymentFrequency
Payment --> PaymentStatus
Notification --> NotificationType
@enduml
