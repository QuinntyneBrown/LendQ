@startuml
skinparam classAttributeIconSize 0
interface IApiClient {
  +SendAsync()
  +RefreshSessionAsync()
}
class AuthState {
  +AccessToken: string?
  +User: UserSummary?
}
class UserSummary {
  +Id: string
  +Roles: List<string>
}
class LoanSummary {
  +Id: string
  +OutstandingBalance: string
}
class PaymentTransaction {
  +Id: string
  +Amount: string
}
class Notification {
  +Id: string
  +IsRead: bool
}
IApiClient --> AuthState
AuthState --> UserSummary
@enduml
