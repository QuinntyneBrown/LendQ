@startuml seq_forgot_password
!theme plain
skinparam dpi 150
skinparam defaultFontSize 10
skinparam sequenceMessageAlign center

title Forgot Password Sequence

actor User
participant "AuthController" as ctrl
participant "AuthService" as svc
participant "UserRepository" as repo
participant "PasswordService" as pwd
participant "EmailService" as email

User -> ctrl : POST /api/auth/forgot-password\n{email}
ctrl -> svc : initiate_password_reset(email)
svc -> repo : find_by_email(email)
repo --> svc : User | None

alt User not found
  note right of svc : Return success anyway\n(prevent enumeration)
end

svc -> pwd : generate_reset_token()
pwd --> svc : token
svc -> repo : save_reset_token(user, token, expiry)
svc -> email : send_email(email, "Reset Password", link)
svc --> ctrl : success
ctrl --> User : 200 "Reset link sent"

...later...

User -> ctrl : POST /api/auth/reset-password\n{token, new_password}
ctrl -> svc : complete_password_reset(token, password)
svc -> pwd : validate_reset_token(token)
pwd --> svc : user_id
svc -> pwd : hash_password(new_password)
pwd --> svc : hash
svc -> repo : update_password(user_id, hash)
svc --> ctrl : success
ctrl --> User : 200 "Password updated"
@enduml
