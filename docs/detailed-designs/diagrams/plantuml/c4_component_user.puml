@startuml c4_component_user
!theme plain
skinparam dpi 150
skinparam defaultFontSize 10
skinparam componentStyle rectangle

title C4 Component — User Management & RBAC

package "Flask REST API" {
  component "**UserController**\n[Blueprint]\nlist, get, create,\nupdate, delete users" as uctrl #438DD5
  component "**RoleController**\n[Blueprint]\nlist roles,\nupdate permissions" as rctrl #438DD5
  component "**AuthMiddleware**\n[Decorator]\nJWT + RBAC check" as mw #fff2cc
  component "**UserService**\n[Service]\nUser CRUD, role assignment" as usvc #438DD5
  component "**RoleService**\n[Service]\nRole & permission mgmt" as rsvc #438DD5
  component "**UserRepository**\n[Repository]" as urepo #85BBF0
  component "**RoleRepository**\n[Repository]" as rrepo #85BBF0
}

uctrl ..> mw
rctrl ..> mw
uctrl --> usvc
rctrl --> rsvc
usvc --> urepo
usvc ..> rrepo
rsvc --> rrepo
@enduml
