@startuml
actor Creditor
participant RecurringLoanController
participant ConsentService
participant RecurringLoanService
database "recurring_loans" as db
queue Outbox
participant AuditService

Creditor -> RecurringLoanController : POST /loans/recurring/{id}/pause
RecurringLoanController -> ConsentService : verify creditor ownership
ConsentService --> RecurringLoanController : allowed
RecurringLoanController -> RecurringLoanService : pause(recurringLoanId, expected_version)
RecurringLoanService -> db : set status = PAUSED\nnullify next_generation_at
RecurringLoanService -> AuditService : record pause audit
RecurringLoanService -> Outbox : recurring_loan.paused
RecurringLoanController --> Creditor : updated recurring loan
@enduml
