@startuml
actor User
participant SavingsGoalController
participant ContributionService
participant BankAccountService
database "savings / bank" as db
queue Outbox

User -> SavingsGoalController : POST /savings/{goalId}/contributions\nIdempotency-Key
SavingsGoalController -> ContributionService : addFunds(goalId, amount)
ContributionService -> BankAccountService : validate & debit account
BankAccountService -> db : record WITHDRAWAL transaction
ContributionService -> db : insert contribution + update goal current_amount
ContributionService -> ContributionService : check if target reached
ContributionService -> Outbox : contribution_posted\n(+ goal_completed if target met)
SavingsGoalController --> User : contribution + updated goal
@enduml
