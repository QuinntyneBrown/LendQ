@startuml
actor User
participant SavingsGoalController
participant AuthorizationService
participant IdempotencyGuard
participant SavingsGoalService
participant BankLedgerService
database "savings_goals / bank_accounts" as db
queue Outbox
participant AuditService

User -> SavingsGoalController : POST /savings/{goalId}/contributions\nIdempotency-Key
SavingsGoalController -> AuthorizationService : require goal ownership
AuthorizationService --> SavingsGoalController : allowed
SavingsGoalController -> IdempotencyGuard : reserve(request scope)
IdempotencyGuard --> SavingsGoalController : key accepted
SavingsGoalController -> SavingsGoalService : addFunds(goalId, accountId, amount)
SavingsGoalService -> db : lock goal + funding account
SavingsGoalService -> BankLedgerService : debit funding account
BankLedgerService -> db : insert bank transaction
SavingsGoalService -> db : insert CREDIT goal entry\nupdate goal current_amount/status
SavingsGoalService -> AuditService : record contribution audit
SavingsGoalService -> Outbox : savings.goal_contributed\n(+ savings.goal_target_met if needed)
SavingsGoalController --> User : goal entry + updated goal
@enduml
