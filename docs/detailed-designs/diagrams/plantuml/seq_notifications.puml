@startuml
participant DomainService
database Outbox
participant Relay
participant BackgroundService
database NotificationStore
participant SSE
participant Email

DomainService -> Outbox : write event in tx
Relay -> Outbox : read pending events
Relay -> BackgroundService : enqueue notification job
BackgroundService -> NotificationStore : create notification + deliveries
BackgroundService -> SSE : push in-app event
BackgroundService -> Email : send email if enabled
@enduml
