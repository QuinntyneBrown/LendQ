@startuml
skinparam classAttributeIconSize 0
class RecurringLoan {
  +id: UUID
  +creditor_id: UUID
  +borrower_id: UUID
  +description_template: string
  +principal_amount: decimal
  +currency: string
  +interest_rate_percent: decimal?
  +repayment_frequency: string
  +installment_count: int
  +recurrence_interval: WEEKLY|BIWEEKLY|MONTHLY
  +start_date: date
  +end_date: date?
  +max_occurrences: int?
  +status: ACTIVE|PAUSED|CANCELLED
  +total_generated: int
  +next_generation_date: date
  +created_at: datetime
}
class GeneratedLoanRecord {
  +id: UUID
  +recurring_loan_id: UUID
  +loan_id: UUID
  +sequence: int
  +generated_at: datetime
}
RecurringLoan "1" -- "*" GeneratedLoanRecord
@enduml
