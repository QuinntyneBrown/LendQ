{
  "name": "lendq-e2e",
  "private": true,
  "scripts": {
    "test": "playwright test --project=chromium-desktop",
    "test:full": "playwright test",
    "test:smoke": "playwright test --project=chromium-desktop --grep @smoke",
    "test:changed": "playwright test --only-changed --project=chromium-desktop",
    "test:last-failed": "playwright test --last-failed --project=chromium-desktop",
    "test:responsive": "playwright test tests/responsive --project=chromium-desktop --project=chromium-tablet --project=chromium-mobile",
    "test:cross-browser": "playwright test --project=chromium-desktop --project=firefox-desktop --project=webkit-desktop --grep @smoke",
    "test:headed": "playwright test --headed",
    "test:ui": "playwright test --ui",
    "test:debug": "playwright test --debug",
    "test:chromium": "playwright test --project=chromium-desktop",
    "test:mobile": "playwright test --project=chromium-mobile",
    "test:tablet": "playwright test --project=chromium-tablet",
    "report": "playwright show-report"
  },
  "devDependencies": {
    "@playwright/test": "^1.52.0",
    "@types/node": "^25.5.0",
    "typescript": "^5.8.0"
  }
}
