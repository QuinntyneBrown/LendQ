@page "/login"
@layout LendQ.Client.Layout.AuthLayout
@using LendQ.Client.Models
@using LendQ.Client.Services
@using LendQ.Client.Components.UI
@using Microsoft.AspNetCore.Components.Forms

@inject IAuthService AuthService
@inject NavigationManager NavigationManager
@inject IToastService ToastService

<div>
    <h2 class="text-center text-2xl font-bold text-gray-900 mb-6">Sign in to your account</h2>

    @if (!string.IsNullOrEmpty(_errorMessage))
    {
        <div class="mb-4 rounded-lg bg-red-50 p-4 text-sm text-red-700">
            @_errorMessage
        </div>
    }

    <EditForm Model="_model" OnValidSubmit="HandleSubmit" FormName="login">
        <DataAnnotationsValidator />

        <div class="space-y-4">
            <div>
                <label for="email" class="block text-sm font-medium text-gray-700 mb-1">Email</label>
                <InputText id="email"
                           @bind-Value="_model.Email"
                           class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500"
                           placeholder="you@example.com" />
                <ValidationMessage For="() => _model.Email" class="mt-1 text-xs text-red-600" />
            </div>

            <div>
                <label for="password" class="block text-sm font-medium text-gray-700 mb-1">Password</label>
                <InputText id="password"
                           type="password"
                           @bind-Value="_model.Password"
                           class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500"
                           placeholder="Enter your password" />
                <ValidationMessage For="() => _model.Password" class="mt-1 text-xs text-red-600" />
            </div>

            <div class="flex items-center justify-end">
                <a href="/forgot-password" class="text-sm font-medium text-indigo-600 hover:text-indigo-500">
                    Forgot Password?
                </a>
            </div>

            <Button Type="submit" IsLoading="_isSubmitting" CssClass="w-full">
                Sign In
            </Button>
        </div>
    </EditForm>

    <p class="mt-6 text-center text-sm text-gray-600">
        Don't have an account?
        <a href="/signup" class="font-medium text-indigo-600 hover:text-indigo-500">Sign Up</a>
    </p>
</div>

@code {
    private LoginFormModel _model = new();
    private bool _isSubmitting;
    private string? _errorMessage;

    private async Task HandleSubmit()
    {
        _errorMessage = null;
        _isSubmitting = true;

        try
        {
            await AuthService.LoginAsync(_model.Email, _model.Password);
            NavigationManager.NavigateTo("/dashboard");
        }
        catch (HttpRequestException)
        {
            _errorMessage = "Invalid email or password. Please try again.";
        }
        catch (Exception)
        {
            _errorMessage = "An unexpected error occurred. Please try again.";
        }
        finally
        {
            _isSubmitting = false;
        }
    }
}
