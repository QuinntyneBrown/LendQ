@page "/forgot-password"
@layout LendQ.Client.Layout.AuthLayout
@using LendQ.Client.Models
@using LendQ.Client.Services
@using LendQ.Client.Components.UI
@using Microsoft.AspNetCore.Components.Forms

@inject IAuthService AuthService
@inject NavigationManager NavigationManager

<div>
    @if (_showSuccess)
    {
        <div class="text-center space-y-4">
            <div class="mx-auto flex h-12 w-12 items-center justify-center rounded-full bg-green-100">
                <svg class="h-6 w-6 text-green-600" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" />
                </svg>
            </div>
            <h2 class="text-2xl font-bold text-gray-900">Check your email</h2>
            <p class="text-sm text-gray-600">
                If an account with that email exists, we've sent a reset link.
            </p>
            <div class="pt-4">
                <a href="/login"
                   class="inline-flex items-center text-sm font-medium text-indigo-600 hover:text-indigo-500">
                    Back to Sign In
                </a>
            </div>
        </div>
    }
    else
    {
        <h2 class="text-center text-2xl font-bold text-gray-900 mb-2">Forgot your password?</h2>
        <p class="text-center text-sm text-gray-600 mb-6">
            Enter your email address and we'll send you a link to reset your password.
        </p>

        @if (!string.IsNullOrEmpty(_errorMessage))
        {
            <div class="mb-4 rounded-lg bg-red-50 p-4 text-sm text-red-700">
                @_errorMessage
            </div>
        }

        <EditForm Model="_model" OnValidSubmit="HandleSubmit" FormName="forgot-password">
            <DataAnnotationsValidator />

            <div class="space-y-4">
                <div>
                    <label for="email" class="block text-sm font-medium text-gray-700 mb-1">Email</label>
                    <InputText id="email"
                               @bind-Value="_model.Email"
                               class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500"
                               placeholder="you@example.com" />
                    <ValidationMessage For="() => _model.Email" class="mt-1 text-xs text-red-600" />
                </div>

                <Button Type="submit" IsLoading="_isSubmitting" CssClass="w-full">
                    Send Reset Link
                </Button>
            </div>
        </EditForm>

        <p class="mt-6 text-center text-sm text-gray-600">
            <a href="/login" class="font-medium text-indigo-600 hover:text-indigo-500">Back to Sign In</a>
        </p>
    }
</div>

@code {
    private ForgotPasswordFormModel _model = new();
    private bool _isSubmitting;
    private bool _showSuccess;
    private string? _errorMessage;

    private async Task HandleSubmit()
    {
        _errorMessage = null;
        _isSubmitting = true;

        try
        {
            await AuthService.ForgotPasswordAsync(_model.Email);
            _showSuccess = true;
        }
        catch (Exception)
        {
            // Always show success to prevent email enumeration
            _showSuccess = true;
        }
        finally
        {
            _isSubmitting = false;
        }
    }
}
