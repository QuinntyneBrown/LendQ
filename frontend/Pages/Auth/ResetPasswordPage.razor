@page "/reset-password/{Token}"
@layout LendQ.Client.Layout.AuthLayout
@using LendQ.Client.Models
@using LendQ.Client.Services
@using LendQ.Client.Components.UI
@using Microsoft.AspNetCore.Components.Forms

@inject IAuthService AuthService
@inject NavigationManager NavigationManager
@inject IToastService ToastService

<div>
    <h2 class="text-center text-2xl font-bold text-gray-900 mb-6">Reset your password</h2>

    @if (!string.IsNullOrEmpty(_errorMessage))
    {
        <div class="mb-4 rounded-lg bg-red-50 p-4 text-sm text-red-700">
            @_errorMessage
        </div>
    }

    <EditForm Model="_model" OnValidSubmit="HandleSubmit" FormName="reset-password">
        <DataAnnotationsValidator />

        <div class="space-y-4">
            <div>
                <label for="password" class="block text-sm font-medium text-gray-700 mb-1">New Password</label>
                <InputText id="password"
                           type="password"
                           @bind-Value="_model.Password"
                           class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500"
                           placeholder="At least 8 characters" />
                <ValidationMessage For="() => _model.Password" class="mt-1 text-xs text-red-600" />
            </div>

            <div>
                <label for="confirm-password" class="block text-sm font-medium text-gray-700 mb-1">Confirm Password</label>
                <InputText id="confirm-password"
                           type="password"
                           @bind-Value="_model.ConfirmPassword"
                           class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500"
                           placeholder="Re-enter your password" />
                <ValidationMessage For="() => _model.ConfirmPassword" class="mt-1 text-xs text-red-600" />
            </div>

            <Button Type="submit" IsLoading="_isSubmitting" CssClass="w-full">
                Reset Password
            </Button>
        </div>
    </EditForm>

    <p class="mt-6 text-center text-sm text-gray-600">
        <a href="/login" class="font-medium text-indigo-600 hover:text-indigo-500">Back to Sign In</a>
    </p>
</div>

@code {
    [Parameter] public string Token { get; set; } = "";

    private ResetPasswordFormModel _model = new();
    private bool _isSubmitting;
    private string? _errorMessage;

    protected override void OnInitialized()
    {
        _model.Token = Token;
    }

    private async Task HandleSubmit()
    {
        _errorMessage = null;
        _isSubmitting = true;

        try
        {
            await AuthService.ResetPasswordAsync(_model.Token, _model.Password, _model.ConfirmPassword);
            ToastService.ShowSuccess("Password reset successfully. Please sign in.");
            NavigationManager.NavigateTo("/login");
        }
        catch (HttpRequestException)
        {
            _errorMessage = "This reset link is invalid or has expired. Please request a new one.";
        }
        catch (Exception)
        {
            _errorMessage = "An unexpected error occurred. Please try again.";
        }
        finally
        {
            _isSubmitting = false;
        }
    }
}
