@using LendQ.Client.Models
@using LendQ.Client.Services
@using LendQ.Client.Components.UI

@inject IAuditService AuditService

<div class="bg-white rounded-xl shadow-sm border overflow-hidden">

    <div class="p-4 border-b border-gray-200">
        <h3 class="text-lg font-semibold text-gray-900">Audit Events</h3>
    </div>

    @* Filters *@
    <div class="p-4 border-b border-gray-200 bg-gray-50">
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-5 gap-3">
            <div>
                <label for="audit-actor" class="block text-xs font-medium text-gray-500 mb-1">Actor</label>
                <input id="audit-actor"
                       type="text"
                       @bind="_actor"
                       placeholder="Search actor..."
                       class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500" />
            </div>

            <div>
                <label for="audit-target" class="block text-xs font-medium text-gray-500 mb-1">Target</label>
                <input id="audit-target"
                       type="text"
                       @bind="_target"
                       placeholder="Search target..."
                       class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500" />
            </div>

            <div>
                <label for="audit-action" class="block text-xs font-medium text-gray-500 mb-1">Action</label>
                <select id="audit-action"
                        @bind="_action"
                        class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 bg-white">
                    <option value="">All Actions</option>
                    <option value="CREATE">Create</option>
                    <option value="UPDATE">Update</option>
                    <option value="DELETE">Delete</option>
                    <option value="LOGIN">Login</option>
                    <option value="LOGOUT">Logout</option>
                    <option value="PAYMENT">Payment</option>
                    <option value="REVERSAL">Reversal</option>
                </select>
            </div>

            <div>
                <label for="audit-from" class="block text-xs font-medium text-gray-500 mb-1">Date From</label>
                <input id="audit-from"
                       type="date"
                       @bind="_dateFrom"
                       class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500" />
            </div>

            <div>
                <label for="audit-to" class="block text-xs font-medium text-gray-500 mb-1">Date To</label>
                <input id="audit-to"
                       type="date"
                       @bind="_dateTo"
                       class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500" />
            </div>
        </div>

        <div class="mt-3 flex justify-end">
            <Button CssClass="text-sm" OnClick="HandleSearch">Search</Button>
        </div>
    </div>

    @* Results *@
    <div class="p-4">
        @if (_loading)
        {
            <LoadingSkeleton Lines="5" />
        }
        else if (_response == null || _response.Items.Count == 0)
        {
            <EmptyState Title="No audit events"
                        Description="No events match your search criteria." />
        }
        else
        {
            @* Desktop table *@
            <div class="hidden md:block overflow-x-auto">
                <table class="min-w-full divide-y divide-gray-200">
                    <thead class="bg-gray-50">
                        <tr>
                            <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Timestamp</th>
                            <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Actor</th>
                            <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Action</th>
                            <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Target</th>
                            <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Details</th>
                        </tr>
                    </thead>
                    <tbody class="bg-white divide-y divide-gray-200">
                        @foreach (var evt in _response.Items)
                        {
                            var dict = evt as IDictionary<string, object>;
                            <tr class="hover:bg-gray-50 transition-colors">
                                <td class="px-4 py-3 text-sm text-gray-500 whitespace-nowrap">@GetProperty(evt, "timestamp")</td>
                                <td class="px-4 py-3 text-sm text-gray-900">@GetProperty(evt, "actor")</td>
                                <td class="px-4 py-3 text-sm">
                                    <Badge Text="@GetProperty(evt, "action")" Variant="info" />
                                </td>
                                <td class="px-4 py-3 text-sm text-gray-900">@GetProperty(evt, "target")</td>
                                <td class="px-4 py-3 text-sm text-gray-500 max-w-xs truncate">@GetProperty(evt, "details")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            @* Mobile cards *@
            <div class="md:hidden space-y-3">
                @foreach (var evt in _response.Items)
                {
                    <div class="bg-white border border-gray-200 rounded-lg p-4 space-y-2">
                        <div class="flex items-center justify-between">
                            <Badge Text="@GetProperty(evt, "action")" Variant="info" />
                            <span class="text-xs text-gray-500">@GetProperty(evt, "timestamp")</span>
                        </div>
                        <div class="text-sm">
                            <span class="text-gray-500">Actor:</span>
                            <span class="font-medium text-gray-900 ml-1">@GetProperty(evt, "actor")</span>
                        </div>
                        <div class="text-sm">
                            <span class="text-gray-500">Target:</span>
                            <span class="font-medium text-gray-900 ml-1">@GetProperty(evt, "target")</span>
                        </div>
                        @{ var details = GetProperty(evt, "details"); }
                        @if (!string.IsNullOrEmpty(details))
                        {
                            <p class="text-xs text-gray-500">@details</p>
                        }
                    </div>
                }
            </div>

            @* Pagination *@
            @if (_response.Pages > 1)
            {
                <div class="mt-4">
                    <Pagination CurrentPage="_response.Page"
                                TotalPages="_response.Pages"
                                OnPageChanged="HandlePageChanged" />
                </div>
            }
        }
    </div>
</div>

@code {
    private PaginatedResponse<object>? _response;
    private bool _loading;
    private int _currentPage = 1;

    private string _actor = "";
    private string _target = "";
    private string _action = "";
    private DateTime? _dateFrom;
    private DateTime? _dateTo;

    private async Task HandleSearch()
    {
        _currentPage = 1;
        await LoadEventsAsync();
    }

    private async Task HandlePageChanged(int page)
    {
        _currentPage = page;
        await LoadEventsAsync();
    }

    private async Task LoadEventsAsync()
    {
        _loading = true;
        StateHasChanged();

        try
        {
            _response = await AuditService.SearchAuditEventsAsync(
                string.IsNullOrEmpty(_actor) ? null : _actor,
                string.IsNullOrEmpty(_target) ? null : _target,
                string.IsNullOrEmpty(_action) ? null : _action,
                _dateFrom,
                _dateTo,
                _currentPage);
        }
        catch (Exception)
        {
            _response = null;
        }
        finally
        {
            _loading = false;
            StateHasChanged();
        }
    }

    private static string GetProperty(object obj, string propertyName)
    {
        if (obj is System.Text.Json.JsonElement jsonElement)
        {
            if (jsonElement.TryGetProperty(propertyName, out var prop))
            {
                return prop.ToString();
            }
        }

        var propInfo = obj.GetType().GetProperty(propertyName,
            System.Reflection.BindingFlags.IgnoreCase | System.Reflection.BindingFlags.Public | System.Reflection.BindingFlags.Instance);
        return propInfo?.GetValue(obj)?.ToString() ?? "";
    }
}
