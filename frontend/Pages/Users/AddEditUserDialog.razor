@using LendQ.Client.Models
@using LendQ.Client.Services
@using LendQ.Client.Components.UI
@using Microsoft.AspNetCore.Components.Forms

@inject IUserService UserService
@inject IToastService ToastService

<Modal IsOpen="@IsOpen" OnClose="@OnClose" Title="@_title">
    <ChildContent>
        @if (!string.IsNullOrEmpty(_errorMessage))
        {
            <div class="mb-4 rounded-lg bg-red-50 p-4 text-sm text-red-700">
                @_errorMessage
            </div>
        }

        <EditForm Model="_model" OnValidSubmit="HandleSubmit">
            <DataAnnotationsValidator />

            <div class="space-y-4">
                <div>
                    <label for="user-name" class="block text-sm font-medium text-gray-700 mb-1">Name</label>
                    <InputText id="user-name"
                               @bind-Value="_model.Name"
                               class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500"
                               placeholder="Full name" />
                    <ValidationMessage For="() => _model.Name" class="mt-1 text-xs text-red-600" />
                </div>

                <div>
                    <label for="user-email" class="block text-sm font-medium text-gray-700 mb-1">Email</label>
                    <InputText id="user-email"
                               @bind-Value="_model.Email"
                               class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500"
                               placeholder="email@example.com" />
                    <ValidationMessage For="() => _model.Email" class="mt-1 text-xs text-red-600" />
                </div>

                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-2">Roles</label>
                    <div class="space-y-2">
                        @foreach (var role in _availableRoles)
                        {
                            var r = role;
                            <label class="flex items-center gap-2 cursor-pointer">
                                <input type="checkbox"
                                       checked="@_model.Roles.Contains(r)"
                                       @onchange="() => ToggleRole(r)"
                                       class="h-4 w-4 text-indigo-600 border-gray-300 rounded focus:ring-indigo-500" />
                                <span class="text-sm text-gray-700">@r</span>
                            </label>
                        }
                    </div>
                </div>

                <div>
                    <label class="flex items-center gap-2 cursor-pointer">
                        <input type="checkbox"
                               checked="@_model.IsActive"
                               @onchange="(e) => _model.IsActive = (bool)(e.Value ?? false)"
                               class="h-4 w-4 text-indigo-600 border-gray-300 rounded focus:ring-indigo-500" />
                        <span class="text-sm font-medium text-gray-700">Active</span>
                    </label>
                </div>

                <div class="flex items-center justify-end gap-3 pt-2">
                    <Button Variant="secondary" OnClick="@OnClose">Cancel</Button>
                    <Button Type="submit" IsLoading="_isSubmitting">
                        @(User == null ? "Add User" : "Save Changes")
                    </Button>
                </div>
            </div>
        </EditForm>
    </ChildContent>
</Modal>

@code {
    [Parameter] public bool IsOpen { get; set; }
    [Parameter] public EventCallback OnClose { get; set; }
    [Parameter] public UserSummary? User { get; set; }
    [Parameter] public EventCallback OnSaved { get; set; }

    private UserFormModel _model = new();
    private bool _isSubmitting;
    private string? _errorMessage;

    private readonly string[] _availableRoles = { "ADMIN", "CREDITOR", "BORROWER" };

    private string _title => User == null ? "Add User" : "Edit User";

    protected override void OnParametersSet()
    {
        if (IsOpen)
        {
            if (User != null)
            {
                _model = new UserFormModel
                {
                    Name = User.Name,
                    Email = User.Email,
                    Roles = new List<string>(User.Roles),
                    IsActive = User.Status == "ACTIVE"
                };
            }
            else
            {
                _model = new UserFormModel { IsActive = true };
            }
            _errorMessage = null;
        }
    }

    private void ToggleRole(string role)
    {
        if (_model.Roles.Contains(role))
        {
            _model.Roles.Remove(role);
        }
        else
        {
            _model.Roles.Add(role);
        }
    }

    private async Task HandleSubmit()
    {
        if (_isSubmitting) return;

        _errorMessage = null;
        _isSubmitting = true;

        try
        {
            if (User == null)
            {
                await UserService.CreateUserAsync(_model);
                ToastService.ShowSuccess("User created successfully.");
            }
            else
            {
                await UserService.UpdateUserAsync(User.Id, _model);
                ToastService.ShowSuccess("User updated successfully.");
            }

            await OnSaved.InvokeAsync();
            await OnClose.InvokeAsync();
        }
        catch (HttpRequestException ex)
        {
            _errorMessage = ex.Message;
        }
        catch (Exception)
        {
            _errorMessage = "An unexpected error occurred. Please try again.";
        }
        finally
        {
            _isSubmitting = false;
        }
    }
}
