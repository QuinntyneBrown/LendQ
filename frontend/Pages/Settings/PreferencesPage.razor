@page "/settings/preferences"
@using LendQ.Client.Models
@using LendQ.Client.Services
@using LendQ.Client.Components.UI
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize]

@inject ISettingsService SettingsService
@inject IToastService ToastService

<div class="space-y-6">

    <h1 class="text-2xl font-bold text-gray-900">Notification Preferences</h1>

    @if (_loading)
    {
        <LoadingSkeleton Lines="8" CssClass="bg-white rounded-xl shadow-sm border p-6" />
    }
    else if (_error != null)
    {
        <div class="rounded-lg bg-red-50 p-4 text-sm text-red-700 flex items-center justify-between">
            <span>@_error</span>
            <button type="button" class="text-red-700 underline font-medium" @onclick="LoadPreferencesAsync">Retry</button>
        </div>
    }
    else if (_prefs != null)
    {
        @* Unsaved changes banner *@
        @if (IsDirty)
        {
            <div class="rounded-lg bg-amber-50 border border-amber-200 p-3 text-sm text-amber-800 flex items-center gap-2">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m9-.75a9 9 0 1 1-18 0 9 9 0 0 1 18 0Zm-9 3.75h.008v.008H12v-.008Z" />
                </svg>
                <span>You have unsaved changes.</span>
            </div>
        }

        <EditForm Model="_prefs" OnValidSubmit="HandleSave">
            <div class="bg-white rounded-xl shadow-sm border divide-y divide-gray-100">

                <div class="px-4 py-5 sm:px-6">
                    <h2 class="text-lg font-medium text-gray-900">Email Notifications</h2>
                    <p class="mt-1 text-sm text-gray-500">Choose which events send you an email notification.</p>
                </div>

                @* Toggle rows *@
                <div class="px-4 py-4 sm:px-6 flex items-center justify-between">
                    <div>
                        <p class="text-sm font-medium text-gray-900">Payment due reminders</p>
                        <p class="text-xs text-gray-500">Get notified when a payment is coming due.</p>
                    </div>
                    <label class="relative inline-flex items-center cursor-pointer">
                        <InputCheckbox @bind-Value="_prefs.PaymentDueEmail" class="sr-only peer" />
                        <div class="w-11 h-6 bg-gray-200 peer-focus:outline-none peer-focus:ring-2 peer-focus:ring-indigo-500 rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:border-gray-300 after:border after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:bg-indigo-600"></div>
                    </label>
                </div>

                <div class="px-4 py-4 sm:px-6 flex items-center justify-between">
                    <div>
                        <p class="text-sm font-medium text-gray-900">Overdue payment alerts</p>
                        <p class="text-xs text-gray-500">Get notified when a payment becomes overdue.</p>
                    </div>
                    <label class="relative inline-flex items-center cursor-pointer">
                        <InputCheckbox @bind-Value="_prefs.PaymentOverdueEmail" class="sr-only peer" />
                        <div class="w-11 h-6 bg-gray-200 peer-focus:outline-none peer-focus:ring-2 peer-focus:ring-indigo-500 rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:border-gray-300 after:border after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:bg-indigo-600"></div>
                    </label>
                </div>

                <div class="px-4 py-4 sm:px-6 flex items-center justify-between">
                    <div>
                        <p class="text-sm font-medium text-gray-900">Payment received confirmations</p>
                        <p class="text-xs text-gray-500">Get notified when a payment is recorded.</p>
                    </div>
                    <label class="relative inline-flex items-center cursor-pointer">
                        <InputCheckbox @bind-Value="_prefs.PaymentReceivedEmail" class="sr-only peer" />
                        <div class="w-11 h-6 bg-gray-200 peer-focus:outline-none peer-focus:ring-2 peer-focus:ring-indigo-500 rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:border-gray-300 after:border after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:bg-indigo-600"></div>
                    </label>
                </div>

                <div class="px-4 py-4 sm:px-6 flex items-center justify-between">
                    <div>
                        <p class="text-sm font-medium text-gray-900">Schedule change updates</p>
                        <p class="text-xs text-gray-500">Get notified when a payment schedule is modified.</p>
                    </div>
                    <label class="relative inline-flex items-center cursor-pointer">
                        <InputCheckbox @bind-Value="_prefs.ScheduleChangedEmail" class="sr-only peer" />
                        <div class="w-11 h-6 bg-gray-200 peer-focus:outline-none peer-focus:ring-2 peer-focus:ring-indigo-500 rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:border-gray-300 after:border after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:bg-indigo-600"></div>
                    </label>
                </div>

                <div class="px-4 py-4 sm:px-6 flex items-center justify-between">
                    <div>
                        <p class="text-sm font-medium text-gray-900">Loan term change updates</p>
                        <p class="text-xs text-gray-500">Get notified when loan terms are modified.</p>
                    </div>
                    <label class="relative inline-flex items-center cursor-pointer">
                        <InputCheckbox @bind-Value="_prefs.LoanModifiedEmail" class="sr-only peer" />
                        <div class="w-11 h-6 bg-gray-200 peer-focus:outline-none peer-focus:ring-2 peer-focus:ring-indigo-500 rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:border-gray-300 after:border after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:bg-indigo-600"></div>
                    </label>
                </div>

                <div class="px-4 py-4 sm:px-6 flex items-center justify-between">
                    <div>
                        <p class="text-sm font-medium text-gray-900">System notices</p>
                        <p class="text-xs text-gray-500">Get notified about system updates and announcements.</p>
                    </div>
                    <label class="relative inline-flex items-center cursor-pointer">
                        <InputCheckbox @bind-Value="_prefs.SystemEmail" class="sr-only peer" />
                        <div class="w-11 h-6 bg-gray-200 peer-focus:outline-none peer-focus:ring-2 peer-focus:ring-indigo-500 rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:border-gray-300 after:border after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:bg-indigo-600"></div>
                    </label>
                </div>
            </div>

            @* Info text *@
            <div class="rounded-lg bg-blue-50 border border-blue-200 p-3 text-sm text-blue-800 flex items-center gap-2">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="m11.25 11.25.041-.02a.75.75 0 0 1 1.063.852l-.708 2.836a.75.75 0 0 0 1.063.853l.041-.021M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Zm-9-3.75h.008v.008H12V8.25Z" />
                </svg>
                <span>In-app notifications are always enabled for all event types.</span>
            </div>

            @* Save button *@
            <div class="flex justify-end">
                <Button Type="submit" IsLoading="_saving" IsDisabled="@(!IsDirty)">
                    Save preferences
                </Button>
            </div>
        </EditForm>
    }
</div>

@code {
    private NotificationPreferences? _prefs;
    private NotificationPreferences? _originalPrefs;
    private bool _loading;
    private bool _saving;
    private string? _error;

    private bool IsDirty => _prefs != null && _originalPrefs != null && (
        _prefs.PaymentDueEmail != _originalPrefs.PaymentDueEmail ||
        _prefs.PaymentOverdueEmail != _originalPrefs.PaymentOverdueEmail ||
        _prefs.PaymentReceivedEmail != _originalPrefs.PaymentReceivedEmail ||
        _prefs.ScheduleChangedEmail != _originalPrefs.ScheduleChangedEmail ||
        _prefs.LoanModifiedEmail != _originalPrefs.LoanModifiedEmail ||
        _prefs.SystemEmail != _originalPrefs.SystemEmail
    );

    protected override async Task OnInitializedAsync()
    {
        await LoadPreferencesAsync();
    }

    private async Task LoadPreferencesAsync()
    {
        _loading = true;
        _error = null;
        StateHasChanged();

        try
        {
            _prefs = await SettingsService.GetPreferencesAsync();
            _originalPrefs = new NotificationPreferences
            {
                PaymentDueEmail = _prefs.PaymentDueEmail,
                PaymentOverdueEmail = _prefs.PaymentOverdueEmail,
                PaymentReceivedEmail = _prefs.PaymentReceivedEmail,
                ScheduleChangedEmail = _prefs.ScheduleChangedEmail,
                LoanModifiedEmail = _prefs.LoanModifiedEmail,
                SystemEmail = _prefs.SystemEmail
            };
        }
        catch (Exception)
        {
            _error = "Failed to load preferences. Please try again.";
        }
        finally
        {
            _loading = false;
            StateHasChanged();
        }
    }

    private async Task HandleSave()
    {
        if (_prefs == null || !IsDirty) return;

        _saving = true;
        _error = null;
        StateHasChanged();

        try
        {
            await SettingsService.UpdatePreferencesAsync(_prefs);
            _originalPrefs = new NotificationPreferences
            {
                PaymentDueEmail = _prefs.PaymentDueEmail,
                PaymentOverdueEmail = _prefs.PaymentOverdueEmail,
                PaymentReceivedEmail = _prefs.PaymentReceivedEmail,
                ScheduleChangedEmail = _prefs.ScheduleChangedEmail,
                LoanModifiedEmail = _prefs.LoanModifiedEmail,
                SystemEmail = _prefs.SystemEmail
            };
            ToastService.ShowSuccess("Preferences saved successfully.");
        }
        catch (Exception)
        {
            _error = "Failed to save preferences. Please try again.";
        }
        finally
        {
            _saving = false;
            StateHasChanged();
        }
    }
}
