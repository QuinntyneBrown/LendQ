@using LendQ.Client.Models
@using LendQ.Client.Services
@using LendQ.Client.Components.UI
@using Microsoft.AspNetCore.Components.Forms

@inject IPaymentService PaymentService
@inject IToastService ToastService

<Modal IsOpen="@IsOpen" OnClose="@OnClose" Title="@_title">
    <ChildContent>
        @if (!string.IsNullOrEmpty(_errorMessage))
        {
            <div class="mb-4 rounded-lg bg-red-50 p-4 text-sm text-red-700">
                @_errorMessage
            </div>
        }

        <EditForm Model="_model" OnValidSubmit="HandleSubmit">
            <DataAnnotationsValidator />

            <div class="space-y-4">
                @if (AdjustmentType == "reschedule")
                {
                    <div>
                        <label for="adj-date" class="block text-sm font-medium text-gray-700 mb-1">New Due Date</label>
                        <InputDate id="adj-date"
                                   @bind-Value="_newDate"
                                   class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500" />
                    </div>
                }
                else
                {
                    <div class="rounded-lg bg-blue-50 p-4 text-sm text-blue-700">
                        <span class="font-medium">@(SelectedInstallmentIds?.Count ?? 0)</span> installment(s) selected to pause.
                    </div>
                }

                <div>
                    <label for="adj-reason" class="block text-sm font-medium text-gray-700 mb-1">Reason</label>
                    <InputTextArea id="adj-reason"
                                   @bind-Value="_model.Reason"
                                   rows="3"
                                   class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500"
                                   placeholder="Explain the reason for this adjustment..." />
                    <ValidationMessage For="() => _model.Reason" class="mt-1 text-xs text-red-600" />
                </div>

                <div>
                    <label for="adj-mode" class="block text-sm font-medium text-gray-700 mb-1">Mode</label>
                    <InputSelect id="adj-mode"
                                 @bind-Value="_model.RequestedMode"
                                 class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 bg-white">
                        <option value="DIRECT_APPLY">Apply Directly</option>
                        <option value="REQUEST_APPROVAL">Request Approval</option>
                    </InputSelect>
                </div>

                <div class="flex items-center justify-end gap-3 pt-2">
                    <Button Variant="secondary" OnClick="@OnClose">Cancel</Button>
                    <Button Type="submit" IsLoading="_isSubmitting">
                        @(AdjustmentType == "reschedule" ? "Reschedule" : "Pause")
                    </Button>
                </div>
            </div>
        </EditForm>
    </ChildContent>
</Modal>

@code {
    [Parameter] public bool IsOpen { get; set; }
    [Parameter] public EventCallback OnClose { get; set; }
    [Parameter] public string LoanId { get; set; } = "";
    [Parameter] public string AdjustmentType { get; set; } = "reschedule";
    [Parameter] public List<string> SelectedInstallmentIds { get; set; } = new();
    [Parameter] public EventCallback OnAdjusted { get; set; }

    private ScheduleAdjustmentFormModel _model = new();
    private DateTime _newDate = DateTime.Today;
    private bool _isSubmitting;
    private string? _errorMessage;

    private string _title => AdjustmentType == "reschedule" ? "Reschedule Installments" : "Pause Installments";

    protected override void OnParametersSet()
    {
        if (IsOpen)
        {
            _model = new ScheduleAdjustmentFormModel
            {
                InstallmentIds = SelectedInstallmentIds ?? new(),
                RequestedMode = "DIRECT_APPLY"
            };
            _newDate = DateTime.Today;
            _errorMessage = null;
        }
    }

    private async Task HandleSubmit()
    {
        if (_isSubmitting) return;

        _errorMessage = null;
        _isSubmitting = true;

        _model.InstallmentIds = SelectedInstallmentIds ?? new();

        if (AdjustmentType == "reschedule")
        {
            _model.NewDueDate = _newDate.ToString("yyyy-MM-dd");
        }

        try
        {
            if (AdjustmentType == "reschedule")
            {
                await PaymentService.RescheduleAsync(LoanId, _model);
                ToastService.ShowSuccess("Installments rescheduled successfully.");
            }
            else
            {
                await PaymentService.PauseAsync(LoanId, _model);
                ToastService.ShowSuccess("Installments paused successfully.");
            }

            await OnAdjusted.InvokeAsync();
            await OnClose.InvokeAsync();
        }
        catch (HttpRequestException ex)
        {
            _errorMessage = ex.Message;
        }
        catch (Exception)
        {
            _errorMessage = "An unexpected error occurred. Please try again.";
        }
        finally
        {
            _isSubmitting = false;
        }
    }
}
