@using LendQ.Client.Models
@using LendQ.Client.Components.UI

<div class="space-y-4">
    @* Filter tabs *@
    <div class="flex flex-wrap gap-2">
        @foreach (var filter in _filters)
        {
            var f = filter;
            <button type="button"
                    class="@(f == _activeFilter
                        ? "bg-indigo-600 text-white"
                        : "bg-white text-gray-700 border border-gray-300 hover:bg-gray-50") px-3 py-1.5 rounded-lg text-sm font-medium transition-colors"
                    @onclick="() => SetFilter(f)">
                @f
            </button>
        }
    </div>

    @if (FilteredTransactions.Count == 0)
    {
        <EmptyState Title="No transactions"
                    Description="There are no payment transactions to display." />
    }
    else
    {
        @* Timeline *@
        <div class="relative">
            <div class="absolute left-4 top-0 bottom-0 w-0.5 bg-gray-200"></div>

            <div class="space-y-6">
                @foreach (var tx in FilteredTransactions)
                {
                    var isReversal = tx.TransactionType == "REVERSAL";
                    var isAdjustment = tx.TransactionType == "ADJUSTMENT";

                    <div class="relative pl-10">
                        @* Timeline dot *@
                        <div class="absolute left-2.5 top-1.5 w-3 h-3 rounded-full border-2 border-white @GetDotColor(tx.TransactionType)"></div>

                        <div class="@(isReversal ? "bg-red-50 border-red-200" : "bg-white border-gray-200") border rounded-lg p-4">
                            <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-2">
                                <div class="flex items-center gap-2">
                                    @* Icon *@
                                    @if (isReversal)
                                    {
                                        <svg class="h-5 w-5 text-red-500 flex-shrink-0" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 10h10a8 8 0 018 8v2M3 10l6 6m-6-6l6-6" />
                                        </svg>
                                    }
                                    else if (isAdjustment)
                                    {
                                        <svg class="h-5 w-5 text-yellow-500 flex-shrink-0" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6V4m0 2a2 2 0 100 4m0-4a2 2 0 110 4m-6 8a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4m6 6v10m6-2a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4" />
                                        </svg>
                                    }
                                    else
                                    {
                                        <svg class="h-5 w-5 text-green-500 flex-shrink-0" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
                                        </svg>
                                    }

                                    <div>
                                        <span class="text-sm font-medium text-gray-900">
                                            @FormatType(tx.TransactionType)
                                        </span>
                                        <span class="text-xs text-gray-500 ml-2">
                                            @tx.PostedAt.ToString("MMM dd, yyyy h:mm tt")
                                        </span>
                                    </div>
                                </div>

                                <span class="@(isReversal ? "line-through text-red-600" : "text-gray-900") text-sm font-semibold">
                                    @tx.Amount.ToString("C")
                                </span>
                            </div>

                            <div class="mt-2 flex flex-wrap items-center gap-2 text-xs text-gray-500">
                                @if (!string.IsNullOrEmpty(tx.PaymentMethod))
                                {
                                    <Badge Text="@FormatPaymentMethod(tx.PaymentMethod)" Variant="default" />
                                }
                                <Badge Text="@FormatType(tx.TransactionType)" Variant="@GetBadgeVariant(tx.TransactionType)" />
                            </div>

                            @if (!string.IsNullOrEmpty(tx.Notes))
                            {
                                <p class="mt-2 text-sm text-gray-600">@tx.Notes</p>
                            }
                        </div>
                    </div>
                }
            </div>
        </div>
    }
</div>

@code {
    [Parameter] public List<PaymentTransaction> Transactions { get; set; } = new();

    private readonly string[] _filters = { "All", "Payments", "Reversals", "Adjustments" };
    private string _activeFilter = "All";

    private List<PaymentTransaction> FilteredTransactions => _activeFilter switch
    {
        "Payments" => Transactions.Where(t => t.TransactionType == "PAYMENT").ToList(),
        "Reversals" => Transactions.Where(t => t.TransactionType == "REVERSAL").ToList(),
        "Adjustments" => Transactions.Where(t => t.TransactionType == "ADJUSTMENT").ToList(),
        _ => Transactions
    };

    private void SetFilter(string filter)
    {
        _activeFilter = filter;
    }

    private static string GetDotColor(string type) => type switch
    {
        "REVERSAL" => "bg-red-500",
        "ADJUSTMENT" => "bg-yellow-500",
        _ => "bg-green-500"
    };

    private static string GetBadgeVariant(string type) => type switch
    {
        "REVERSAL" => "danger",
        "ADJUSTMENT" => "warning",
        _ => "success"
    };

    private static string FormatType(string type) => type switch
    {
        "REVERSAL" => "Reversal",
        "ADJUSTMENT" => "Adjustment",
        "PAYMENT" => "Payment",
        _ => type
    };

    private static string FormatPaymentMethod(string method) => method switch
    {
        "BANK_TRANSFER" => "Bank Transfer",
        "CASH" => "Cash",
        "CARD" => "Card",
        "OTHER" => "Other",
        _ => method
    };
}
