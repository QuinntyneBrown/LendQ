@using LendQ.Client.Models
@using LendQ.Client.Services
@using LendQ.Client.Components.UI
@using Microsoft.AspNetCore.Components.Forms

@inject IPaymentService PaymentService
@inject IToastService ToastService

<Modal IsOpen="@IsOpen" OnClose="@OnClose" Title="Record Payment">
    <ChildContent>
        @if (!string.IsNullOrEmpty(_errorMessage))
        {
            <div class="mb-4 rounded-lg bg-red-50 p-4 text-sm text-red-700">
                @_errorMessage
            </div>
        }

        <EditForm Model="_model" OnValidSubmit="HandleSubmit">
            <DataAnnotationsValidator />

            <div class="space-y-4">
                <div>
                    <label for="pay-amount" class="block text-sm font-medium text-gray-700 mb-1">Amount</label>
                    <InputNumber id="pay-amount"
                                 @bind-Value="_model.Amount"
                                 class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500" />
                    <ValidationMessage For="() => _model.Amount" class="mt-1 text-xs text-red-600" />
                </div>

                <div>
                    <label for="pay-date" class="block text-sm font-medium text-gray-700 mb-1">Date</label>
                    <InputDate id="pay-date"
                               @bind-Value="_model.PostedAt"
                               class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500" />
                    <ValidationMessage For="() => _model.PostedAt" class="mt-1 text-xs text-red-600" />
                </div>

                <div>
                    <label for="pay-method" class="block text-sm font-medium text-gray-700 mb-1">Payment Method</label>
                    <InputSelect id="pay-method"
                                 @bind-Value="_model.PaymentMethod"
                                 class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 bg-white">
                        <option value="">-- Select --</option>
                        <option value="CASH">Cash</option>
                        <option value="BANK_TRANSFER">Bank Transfer</option>
                        <option value="CARD">Card</option>
                        <option value="OTHER">Other</option>
                    </InputSelect>
                    <ValidationMessage For="() => _model.PaymentMethod" class="mt-1 text-xs text-red-600" />
                </div>

                <div>
                    <label for="pay-notes" class="block text-sm font-medium text-gray-700 mb-1">Notes</label>
                    <InputTextArea id="pay-notes"
                                   @bind-Value="_model.Notes"
                                   rows="3"
                                   class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500"
                                   placeholder="Optional notes..." />
                </div>

                <div class="flex items-center justify-end gap-3 pt-2">
                    <Button Variant="secondary" OnClick="@OnClose">Cancel</Button>
                    <Button Type="submit" IsLoading="_isSubmitting">Record Payment</Button>
                </div>
            </div>
        </EditForm>
    </ChildContent>
</Modal>

@code {
    [Parameter] public bool IsOpen { get; set; }
    [Parameter] public EventCallback OnClose { get; set; }
    [Parameter] public string LoanId { get; set; } = "";
    [Parameter] public EventCallback OnPaymentRecorded { get; set; }

    private RecordPaymentFormModel _model = new() { PostedAt = DateTime.Today };
    private bool _isSubmitting;
    private string? _errorMessage;

    protected override void OnParametersSet()
    {
        if (IsOpen)
        {
            _model = new RecordPaymentFormModel { PostedAt = DateTime.Today };
            _errorMessage = null;
        }
    }

    private async Task HandleSubmit()
    {
        if (_isSubmitting) return;

        _errorMessage = null;
        _isSubmitting = true;

        try
        {
            var result = await PaymentService.RecordPaymentAsync(LoanId, _model);
            ToastService.ShowSuccess($"Payment recorded. Transaction ID: {result.Id}");
            await OnPaymentRecorded.InvokeAsync();
            await OnClose.InvokeAsync();
        }
        catch (HttpRequestException ex)
        {
            _errorMessage = ex.Message;
        }
        catch (Exception)
        {
            _errorMessage = "An unexpected error occurred. Please try again.";
        }
        finally
        {
            _isSubmitting = false;
        }
    }
}
