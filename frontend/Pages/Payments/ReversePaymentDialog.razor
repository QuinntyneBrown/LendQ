@using LendQ.Client.Models
@using LendQ.Client.Services
@using LendQ.Client.Components.UI
@using Microsoft.AspNetCore.Components.Forms

@inject IPaymentService PaymentService
@inject IToastService ToastService

<Modal IsOpen="@IsOpen" OnClose="@OnClose" Title="Reverse Payment">
    <ChildContent>
        <div class="mb-4 rounded-lg bg-yellow-50 border border-yellow-200 p-4">
            <div class="flex">
                <svg class="h-5 w-5 text-yellow-400 mr-2 flex-shrink-0" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor">
                    <path fill-rule="evenodd" d="M8.257 3.099c.765-1.36 2.722-1.36 3.486 0l5.58 9.92c.75 1.334-.213 2.98-1.742 2.98H4.42c-1.53 0-2.493-1.646-1.743-2.98l5.58-9.92zM11 13a1 1 0 11-2 0 1 1 0 012 0zm-1-8a1 1 0 00-1 1v3a1 1 0 002 0V6a1 1 0 00-1-1z" clip-rule="evenodd" />
                </svg>
                <p class="text-sm text-yellow-700">
                    This reversal is permanent and cannot be undone. The payment amount will be deducted from the loan balance.
                </p>
            </div>
        </div>

        @if (!string.IsNullOrEmpty(_errorMessage))
        {
            <div class="mb-4 rounded-lg bg-red-50 p-4 text-sm text-red-700">
                @_errorMessage
            </div>
        }

        <EditForm Model="_model" OnValidSubmit="HandleSubmit">
            <DataAnnotationsValidator />

            <div class="space-y-4">
                <div>
                    <label for="rev-reason" class="block text-sm font-medium text-gray-700 mb-1">Reason for reversal</label>
                    <InputTextArea id="rev-reason"
                                   @bind-Value="_model.Reason"
                                   rows="4"
                                   class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500"
                                   placeholder="Explain why this payment is being reversed..." />
                    <ValidationMessage For="() => _model.Reason" class="mt-1 text-xs text-red-600" />
                </div>

                <div class="flex items-center justify-end gap-3 pt-2">
                    <Button Variant="secondary" OnClick="@OnClose">Cancel</Button>
                    <Button Type="submit" Variant="destructive" IsLoading="_isSubmitting">Confirm Reversal</Button>
                </div>
            </div>
        </EditForm>
    </ChildContent>
</Modal>

@code {
    [Parameter] public bool IsOpen { get; set; }
    [Parameter] public EventCallback OnClose { get; set; }
    [Parameter] public string PaymentId { get; set; } = "";
    [Parameter] public EventCallback OnReversed { get; set; }

    private ReversalFormModel _model = new();
    private bool _isSubmitting;
    private string? _errorMessage;

    protected override void OnParametersSet()
    {
        if (IsOpen)
        {
            _model = new ReversalFormModel();
            _errorMessage = null;
        }
    }

    private async Task HandleSubmit()
    {
        if (_isSubmitting) return;

        _errorMessage = null;
        _isSubmitting = true;

        try
        {
            await PaymentService.ReversePaymentAsync(PaymentId, _model.Reason);
            ToastService.ShowSuccess("Payment reversed successfully.");
            await OnReversed.InvokeAsync();
            await OnClose.InvokeAsync();
        }
        catch (HttpRequestException ex)
        {
            _errorMessage = ex.Message;
        }
        catch (Exception)
        {
            _errorMessage = "An unexpected error occurred. Please try again.";
        }
        finally
        {
            _isSubmitting = false;
        }
    }
}
