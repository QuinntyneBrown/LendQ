@using LendQ.Client.Models
@using LendQ.Client.Services
@using LendQ.Client.Components.UI
@using Microsoft.AspNetCore.Components.Forms

@inject ILoanService LoanService
@inject IToastService ToastService

<Modal IsOpen="@IsOpen" OnClose="@OnClose" Title="Request Change">
    <ChildContent>
        @if (!string.IsNullOrEmpty(_errorMessage))
        {
            <div class="mb-4 rounded-lg bg-red-50 p-4 text-sm text-red-700">
                @_errorMessage
            </div>
        }

        <EditForm Model="_model" OnValidSubmit="HandleSubmit">
            <DataAnnotationsValidator />

            <div class="space-y-4">
                <div>
                    <label for="cr-type" class="block text-sm font-medium text-gray-700 mb-1">Change Type</label>
                    <InputSelect id="cr-type"
                                 @bind-Value="_model.Type"
                                 class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 bg-white">
                        <option value="">-- Select Type --</option>
                        <option value="TERM_CHANGE">Term Change</option>
                        <option value="RESCHEDULE">Reschedule</option>
                        <option value="PAUSE">Pause</option>
                    </InputSelect>
                    <ValidationMessage For="() => _model.Type" class="mt-1 text-xs text-red-600" />
                </div>

                <div>
                    <label for="cr-reason" class="block text-sm font-medium text-gray-700 mb-1">Reason</label>
                    <InputTextArea id="cr-reason"
                                   @bind-Value="_model.Reason"
                                   rows="4"
                                   class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500"
                                   placeholder="Explain why you are requesting this change..." />
                    <ValidationMessage For="() => _model.Reason" class="mt-1 text-xs text-red-600" />
                </div>

                <div class="flex items-center justify-end gap-3 pt-2">
                    <Button Variant="secondary" OnClick="@OnClose">Cancel</Button>
                    <Button Type="submit" IsLoading="_isSubmitting">Submit Request</Button>
                </div>
            </div>
        </EditForm>
    </ChildContent>
</Modal>

@code {
    [Parameter] public bool IsOpen { get; set; }
    [Parameter] public EventCallback OnClose { get; set; }
    [Parameter] public string LoanId { get; set; } = "";

    private ChangeRequestFormModel _model = new();
    private bool _isSubmitting;
    private string? _errorMessage;

    protected override void OnParametersSet()
    {
        if (IsOpen)
        {
            _model = new ChangeRequestFormModel();
            _errorMessage = null;
        }
    }

    private async Task HandleSubmit()
    {
        if (_isSubmitting) return;

        _errorMessage = null;
        _isSubmitting = true;

        try
        {
            await LoanService.CreateChangeRequestAsync(LoanId, _model);
            ToastService.ShowSuccess("Change request submitted successfully.");
            await OnClose.InvokeAsync();
        }
        catch (HttpRequestException ex)
        {
            _errorMessage = ex.Message;
        }
        catch (Exception)
        {
            _errorMessage = "An unexpected error occurred. Please try again.";
        }
        finally
        {
            _isSubmitting = false;
        }
    }
}
