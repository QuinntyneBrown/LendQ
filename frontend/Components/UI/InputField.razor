@namespace LendQ.Client.Components.UI

<div class="@CssClass">
    <label for="@_computedId" class="block text-sm font-medium text-gray-700 mb-1">@Label</label>
    <input id="@_computedId"
           type="@Type"
           placeholder="@Placeholder"
           value="@Value"
           disabled="@IsDisabled"
           class="@InputCssClass"
           aria-describedby="@(HasError ? $"{_computedId}-error" : null)"
           aria-invalid="@(HasError ? "true" : null)"
           @oninput="HandleInput" />
    @if (!string.IsNullOrEmpty(HelpText) && !HasError)
    {
        <p class="mt-1 text-xs text-gray-500">@HelpText</p>
    }
    @if (HasError)
    {
        <p id="@($"{_computedId}-error")" class="mt-1 text-xs text-red-600">@ErrorMessage</p>
    }
</div>

@code {
    [Parameter] public string Label { get; set; } = "";
    [Parameter] public string Type { get; set; } = "text";
    [Parameter] public string Placeholder { get; set; } = "";
    [Parameter] public string? HelpText { get; set; }
    [Parameter] public string? ErrorMessage { get; set; }
    [Parameter] public string Value { get; set; } = "";
    [Parameter] public EventCallback<string> ValueChanged { get; set; }
    [Parameter] public bool IsDisabled { get; set; }
    [Parameter] public string CssClass { get; set; } = "";
    [Parameter] public string Id { get; set; } = "";

    private string _computedId => string.IsNullOrEmpty(Id)
        ? Label.ToLowerInvariant().Replace(" ", "-")
        : Id;

    private bool HasError => !string.IsNullOrEmpty(ErrorMessage);

    private string InputCssClass =>
        $"w-full px-3 py-2 border rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 {(HasError ? "border-red-500" : "border-gray-300")}";

    private async Task HandleInput(ChangeEventArgs e)
    {
        var newValue = e.Value?.ToString() ?? "";
        await ValueChanged.InvokeAsync(newValue);
    }
}
