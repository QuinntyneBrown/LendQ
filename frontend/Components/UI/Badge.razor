@namespace LendQ.Client.Components.UI

<span class="@ComputedCssClass">@Text</span>

@code {
    [Parameter] public string Text { get; set; } = "";
    [Parameter] public string Variant { get; set; } = "default";

    private string ComputedCssClass
    {
        get
        {
            var variantClasses = Variant switch
            {
                "success" => "bg-green-100 text-green-800",
                "warning" => "bg-yellow-100 text-yellow-800",
                "danger" => "bg-red-100 text-red-800",
                "info" => "bg-blue-100 text-blue-800",
                _ => "bg-gray-100 text-gray-800"
            };

            return $"inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium {variantClasses}";
        }
    }
}
