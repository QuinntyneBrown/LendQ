@namespace LendQ.Client.Components.Shared
@using LendQ.Client.Services
@inject IToastService ToastService
@implements IDisposable

<div class="fixed z-[100] bottom-4 left-1/2 -translate-x-1/2 sm:translate-x-0 sm:bottom-auto sm:top-4 sm:right-4 sm:left-auto flex flex-col gap-2 w-full max-w-sm px-4 sm:px-0">
    @foreach (var toast in _toasts)
    {
        <div class="@GetToastCssClass(toast.Type) rounded-lg shadow-lg p-4 flex items-start gap-3 animate-slide-in">
            <div class="flex-shrink-0">
                @switch (toast.Type)
                {
                    case ToastType.Success:
                        <svg class="h-5 w-5 text-green-600" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                        </svg>
                        break;
                    case ToastType.Error:
                        <svg class="h-5 w-5 text-red-600" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
                        </svg>
                        break;
                    case ToastType.Warning:
                        <svg class="h-5 w-5 text-yellow-600" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4.5c-.77-.833-2.694-.833-3.464 0L3.34 16.5c-.77.833.192 2.5 1.732 2.5z" />
                        </svg>
                        break;
                    case ToastType.Info:
                        <svg class="h-5 w-5 text-blue-600" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M12 2a10 10 0 100 20 10 10 0 000-20z" />
                        </svg>
                        break;
                }
            </div>
            <p class="flex-1 text-sm font-medium">@toast.Message</p>
            <button type="button"
                    class="flex-shrink-0 text-gray-400 hover:text-gray-600 transition-colors"
                    @onclick="() => DismissToast(toast.Id)">
                <svg class="h-4 w-4" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
                </svg>
            </button>
        </div>
    }
</div>

@code {
    private readonly List<ToastMessage> _toasts = new();

    protected override void OnInitialized()
    {
        ToastService.OnToastAdded += HandleToastAdded;
    }

    private async void HandleToastAdded(ToastMessage toast)
    {
        await InvokeAsync(() =>
        {
            _toasts.Add(toast);
            StateHasChanged();
        });

        _ = RemoveAfterDelay(toast.Id);
    }

    private async Task RemoveAfterDelay(string id)
    {
        await Task.Delay(5000);
        await InvokeAsync(() =>
        {
            _toasts.RemoveAll(t => t.Id == id);
            StateHasChanged();
        });
    }

    private void DismissToast(string id)
    {
        _toasts.RemoveAll(t => t.Id == id);
    }

    private string GetToastCssClass(ToastType type) => type switch
    {
        ToastType.Success => "bg-green-50 border border-green-200 text-green-800",
        ToastType.Error => "bg-red-50 border border-red-200 text-red-800",
        ToastType.Warning => "bg-yellow-50 border border-yellow-200 text-yellow-800",
        ToastType.Info => "bg-blue-50 border border-blue-200 text-blue-800",
        _ => "bg-gray-50 border border-gray-200 text-gray-800"
    };

    public void Dispose()
    {
        ToastService.OnToastAdded -= HandleToastAdded;
    }
}
