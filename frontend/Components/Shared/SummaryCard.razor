@namespace LendQ.Client.Components.Shared

<div class="@CardCssClass">
    <div class="flex items-center justify-between">
        <div>
            <p class="text-sm font-medium text-gray-500">@Title</p>
            <p class="mt-1 text-2xl font-semibold text-gray-900">@Value</p>
        </div>
        @if (!string.IsNullOrEmpty(Icon))
        {
            <div class="text-2xl">@Icon</div>
        }
    </div>
</div>

@code {
    [Parameter] public string Title { get; set; } = "";
    [Parameter] public string Value { get; set; } = "";
    [Parameter] public string? Icon { get; set; }
    [Parameter] public string Variant { get; set; } = "default";

    private string CardCssClass => Variant switch
    {
        "warning" => "bg-yellow-50 border-yellow-200 rounded-xl shadow-sm border p-6",
        "danger" => "bg-red-50 border-red-200 rounded-xl shadow-sm border p-6",
        _ => "bg-white rounded-xl shadow-sm border p-6"
    };
}
