@namespace LendQ.Client.Components.Shared
@using LendQ.Client.Services
@inject INotificationService NotificationService
@inject NavigationManager NavigationManager
@implements IDisposable

<button type="button"
        class="relative text-gray-500 hover:text-gray-700 focus:outline-none"
        @onclick="HandleClick">
    <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M14.857 17.082a23.848 23.848 0 0 0 5.454-1.31A8.967 8.967 0 0 1 18 9.75V9A6 6 0 0 0 6 9v.75a8.967 8.967 0 0 1-2.312 6.022c1.733.64 3.56 1.085 5.455 1.31m5.714 0a24.255 24.255 0 0 1-5.714 0m5.714 0a3 3 0 1 1-5.714 0" />
    </svg>
    @if (_unreadCount > 0)
    {
        <span class="absolute -top-1 -right-1 flex items-center justify-center h-5 min-w-[1.25rem] px-1 text-xs font-bold text-white bg-red-500 rounded-full">
            @(_unreadCount > 99 ? "99+" : _unreadCount)
        </span>
    }
</button>

@code {
    private int _unreadCount;

    protected override void OnInitialized()
    {
        _unreadCount = NotificationService.UnreadCount;
        NotificationService.OnChange += HandleChange;
    }

    private void HandleClick()
    {
        NavigationManager.NavigateTo("/notifications");
    }

    private void HandleChange()
    {
        _unreadCount = NotificationService.UnreadCount;
        InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        NotificationService.OnChange -= HandleChange;
    }
}
