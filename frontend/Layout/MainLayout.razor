@inherits LayoutComponentBase
@using LendQ.Client.Services
@using LendQ.Client.Components.Shared
@inject IAuthService AuthService
@inject INotificationService NotificationService
@inject NavigationManager Navigation

<div class="flex h-screen bg-gray-50">
    @* Desktop sidebar (hidden below lg) *@
    <aside class="hidden lg:flex lg:flex-col lg:w-64 bg-white border-r border-gray-200">
        <div class="flex items-center h-16 px-6 border-b border-gray-200">
            <h1 class="text-xl font-bold text-indigo-600">LendQ</h1>
        </div>
        <NavMenu />
    </aside>

    <div class="flex-1 flex flex-col overflow-hidden">
        @* Top header *@
        <Header OnToggleSidebar="ToggleMobileSidebar" />

        @* Main content area *@
        <main class="flex-1 overflow-y-auto p-4 md:p-6 lg:p-8">
            <ErrorBoundary @ref="_errorBoundary">
                <ChildContent>
                    @Body
                </ChildContent>
                <ErrorContent>
                    <div class="text-center py-12">
                        <p class="text-red-600 mb-4">An unexpected error occurred.</p>
                        <button class="text-indigo-600 hover:text-indigo-800 font-medium" @onclick="Recover">Try again</button>
                    </div>
                </ErrorContent>
            </ErrorBoundary>
        </main>

        @* Mobile bottom tab bar (visible below md) *@
        <nav class="md:hidden flex items-center justify-around bg-white border-t border-gray-200 h-16 px-2">
            <NavLink href="/dashboard" class="flex flex-col items-center text-xs text-gray-600 hover:text-indigo-600" ActiveClass="text-indigo-600" Match="NavLinkMatch.Prefix">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 mb-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6A2.25 2.25 0 0 1 6 3.75h2.25A2.25 2.25 0 0 1 10.5 6v2.25a2.25 2.25 0 0 1-2.25 2.25H6a2.25 2.25 0 0 1-2.25-2.25V6ZM3.75 15.75A2.25 2.25 0 0 1 6 13.5h2.25a2.25 2.25 0 0 1 2.25 2.25V18a2.25 2.25 0 0 1-2.25 2.25H6A2.25 2.25 0 0 1 3.75 18v-2.25ZM13.5 6a2.25 2.25 0 0 1 2.25-2.25H18A2.25 2.25 0 0 1 20.25 6v2.25A2.25 2.25 0 0 1 18 10.5h-2.25a2.25 2.25 0 0 1-2.25-2.25V6ZM13.5 15.75a2.25 2.25 0 0 1 2.25-2.25H18a2.25 2.25 0 0 1 2.25 2.25V18A2.25 2.25 0 0 1 18 20.25h-2.25A2.25 2.25 0 0 1 13.5 18v-2.25Z" />
                </svg>
                Dashboard
            </NavLink>
            <NavLink href="/loans" class="flex flex-col items-center text-xs text-gray-600 hover:text-indigo-600" ActiveClass="text-indigo-600" Match="NavLinkMatch.Prefix">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 mb-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 18.75a60.07 60.07 0 0 1 15.797 2.101c.727.198 1.453-.342 1.453-1.096V18.75M3.75 4.5v.75A.75.75 0 0 1 3 6h-.75m0 0v-.375c0-.621.504-1.125 1.125-1.125H20.25M2.25 6v9m18-10.5v.75c0 .414.336.75.75.75h.75m-1.5-1.5h.375c.621 0 1.125.504 1.125 1.125v9.75c0 .621-.504 1.125-1.125 1.125h-.375m1.5-1.5H21a.75.75 0 0 0-.75.75v.75m0 0H3.75m0 0h-.375a1.125 1.125 0 0 1-1.125-1.125V15m1.5 1.5v-.75A.75.75 0 0 0 3 15h-.75M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Zm3 0h.008v.008H18V10.5Zm-12 0h.008v.008H6V10.5Z" />
                </svg>
                Loans
            </NavLink>
            <NavLink href="/notifications" class="flex flex-col items-center text-xs text-gray-600 hover:text-indigo-600" ActiveClass="text-indigo-600" Match="NavLinkMatch.Prefix">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 mb-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M14.857 17.082a23.848 23.848 0 0 0 5.454-1.31A8.967 8.967 0 0 1 18 9.75V9A6 6 0 0 0 6 9v.75a8.967 8.967 0 0 1-2.312 6.022c1.733.64 3.56 1.085 5.455 1.31m5.714 0a24.255 24.255 0 0 1-5.714 0m5.714 0a3 3 0 1 1-5.714 0" />
                </svg>
                Alerts
            </NavLink>
            <NavLink href="/settings/preferences" class="flex flex-col items-center text-xs text-gray-600 hover:text-indigo-600" ActiveClass="text-indigo-600" Match="NavLinkMatch.Prefix">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 mb-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M9.594 3.94c.09-.542.56-.94 1.11-.94h2.593c.55 0 1.02.398 1.11.94l.213 1.281c.063.374.313.686.645.87.074.04.147.083.22.127.325.196.72.257 1.075.124l1.217-.456a1.125 1.125 0 0 1 1.37.49l1.296 2.247a1.125 1.125 0 0 1-.26 1.431l-1.003.827c-.293.241-.438.613-.43.992a7.723 7.723 0 0 1 0 .255c-.008.378.137.75.43.991l1.004.827c.424.35.534.955.26 1.43l-1.298 2.247a1.125 1.125 0 0 1-1.369.491l-1.217-.456c-.355-.133-.75-.072-1.076.124a6.47 6.47 0 0 1-.22.128c-.331.183-.581.495-.644.869l-.213 1.281c-.09.543-.56.94-1.11.94h-2.594c-.55 0-1.019-.398-1.11-.94l-.213-1.281c-.062-.374-.312-.686-.644-.87a6.52 6.52 0 0 1-.22-.127c-.325-.196-.72-.257-1.076-.124l-1.217.456a1.125 1.125 0 0 1-1.369-.49l-1.297-2.247a1.125 1.125 0 0 1 .26-1.431l1.004-.827c.292-.24.437-.613.43-.991a6.932 6.932 0 0 1 0-.255c.007-.38-.138-.751-.43-.992l-1.004-.827a1.125 1.125 0 0 1-.26-1.43l1.297-2.247a1.125 1.125 0 0 1 1.37-.491l1.216.456c.356.133.751.072 1.076-.124.072-.044.146-.086.22-.128.332-.183.582-.495.644-.869l.214-1.28Z" />
                    <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" />
                </svg>
                Settings
            </NavLink>
        </nav>
    </div>

    @* Mobile sidebar overlay *@
    @if (_isMobileSidebarOpen)
    {
        <div class="fixed inset-0 z-40 lg:hidden">
            <div class="fixed inset-0 bg-black/50" @onclick="ToggleMobileSidebar"></div>
            <aside class="fixed inset-y-0 left-0 w-64 bg-white shadow-xl z-50">
                <div class="flex items-center justify-between h-16 px-6 border-b border-gray-200">
                    <h1 class="text-xl font-bold text-indigo-600">LendQ</h1>
                    <button @onclick="ToggleMobileSidebar" class="text-gray-500 hover:text-gray-700">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12" />
                        </svg>
                    </button>
                </div>
                <NavMenu />
            </aside>
        </div>
    }
</div>

<ToastContainer />

@code {
    private bool _isMobileSidebarOpen;
    private ErrorBoundary? _errorBoundary;

    private void ToggleMobileSidebar()
    {
        _isMobileSidebarOpen = !_isMobileSidebarOpen;
    }

    private void Recover()
    {
        _errorBoundary?.Recover();
    }
}
